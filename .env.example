# OmniRoute — primary inference for Hermes 4
# Get your API key from omniroute.online
OMNIROUTE_API_KEY="your-omniroute-api-key"
OMNIROUTE_BASE_URL="https://api.omniroute.online/v1"
OMNIROUTE_MODEL="auto"

# Gemini — fallback / used elsewhere in the stack
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App URL (injected by AI Studio at runtime)
APP_URL="MY_APP_URL"

# Optional: custom path for local observation store (defaults to ./hermes-memory.json)
# HERMES_STORE_PATH="/data/hermes-memory.json"
